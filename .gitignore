```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.class
*.exe
*.dll
*.so
*.a
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
.env.*

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Editors
.vscode/
.idea/

# Coverage reports
coverage/
htmlcov/
.coverage

# Distribution / packaging
dist/
build/
*.tar.gz
*.zip

# OS generated files
.DS_Store
Thumbs.db

# Cache directories
.mypy_cache/
.pytest_cache/
target/
.gradle/

# Compression files
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.bz2
*.tar.xz
*.tar.zst
```